<style>
  /* Menghindari elemen keluar dari lebar layar */
  * {
    box-sizing: border-box;
  }

  .product-container {
    width: 100%;
    max-width: 1200px; /* Batas maksimal agar tidak terlalu lebar di PC */
    margin: 0 auto;
    padding: 10px;
    font-family: sans-serif;
  }

  .product-list {
    display: grid;
    /* Membuat kolom otomatis: minimal 250px, maksimal mengisi sisa ruang */
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 12px;
    width: 100%;
  }

  .product-item {
    width: 100%;
  }

  .product-item a {
    text-decoration: none;
    display: block;
    width: 100%;
  }

  .product-button {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 80px; /* Menjaga tinggi tombol tetap seragam */
    background-color: #fc0303;
    color: white;
    padding: 10px 15px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s, background-color 0.2s;
  }

  .product-button:hover {
    background-color: #d10202;
    transform: translateY(-2px); /* Efek sedikit mengangkat saat disentuh */
  }

  .product-image {
    width: 55px;
    height: 55px;
    flex-shrink: 0; /* Gambar tidak akan gepeng */
    object-fit: cover;
    background-color: white;
    border-radius: 5px;
    margin-right: 12px;
  }

  .product-name {
    flex-grow: 1;
    text-align: left; /* Teks rata kiri agar lebih rapi di samping gambar */
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  /* Responsif khusus HP layar sangat kecil */
  @media (max-width: 320px) {
    .product-name {
      font-size: 12px;
    }
    .product-image {
      width: 45px;
      height: 45px;
    }
  }
</style>
